# --- Shopify Storefront API ---
# Found in Shopify Admin > Settings > Apps and sales channels > Develop apps
# Create a custom app with Storefront API access, then copy these values.

NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-api-token
SHOPIFY_STOREFRONT_API_VERSION=2025-01

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://www.bonesyde.com

# --- Newsletter (optional, wire up to Klaviyo/Shopify forms etc.) ---
# NEWSLETTER_ENDPOINT=
